# macOS and editor state
.DS_Store
**/.DS_Store
.obsidian/workspace*.json
.obsidian/cache/
knowledge/.obsidian/
.trash/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Local environment and credentials
.env
.env.*
!.env.example
*.pem
*.key

# Large local media. Research metadata, comments, captions, and thumbnails stay tracked.
YouTube/**/*.mp4
YouTube/**/*.mkv
YouTube/**/*.webm
YouTube/**/*.wav
YouTube/**/*.m4a
YouTube/**/*.mp3

# Rebuildable knowledge index and local run state. Keep one ready-to-query
# SQLite snapshot in Git so reviewers can inspect the corpus after clone.
knowledge/_index/*
!knowledge/_index/gconf.sqlite
knowledge/runs/
